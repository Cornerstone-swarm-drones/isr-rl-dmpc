<?xml version="1.0"?>
<!--
  drone.urdf — PyBullet-compatible URDF for the ISR-DMPC swarm drone.

  Model source : hector_quadrotor (TU Darmstadt)
                 https://github.com/tu-darmstadt-ros-pkg/hector_quadrotor
  Mesh licence : BSD (see meshes/hector_quadrotor/LICENSE.txt)

  Physical parameters are tuned for the hector_quadrotor airframe used in
  the ISR-DMPC simulation and match the values in config/drone_specs.yaml.

  Coordinate convention
  ---------------------
  - base_link  : body-fixed frame, origin at CoM, +Z up (ENU).
  - camera_link: forward-facing camera, 15° downward tilt.
  - imu_link   : co-located with base_link for inertial sensing.
  - gps_link   : mounted on top of the body.

  Usage with PyBullet
  -------------------
    import pybullet as p
    from isr_rl_dmpc.models.hector_quadrotor import get_urdf_path
    drone_id = p.loadURDF(get_urdf_path(), basePosition=[x, y, z])
-->
<robot name="isr_dmpc_drone">

  <!-- ═══════════════════════════════════════════════════════════════════════
       BASE LINK  (CoM / body frame)
  ═══════════════════════════════════════════════════════════════════════════ -->
  <link name="base_link">

    <inertial>
      <!-- hector_quadrotor airframe: 1.477 kg -->
      <mass value="1.477"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01152" ixy="0.0" ixz="0.0"
               iyy="0.01152" iyz="0.0"
               izz="0.02180"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- STL is in millimeters; scale 0.001 converts to metres -->
        <mesh filename="../meshes/hector_quadrotor/quadrotor_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="drone_body">
        <color rgba="0.2 0.5 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Use a bounding box for fast collision (rotor span ~0.55 m) -->
        <box size="0.55 0.55 0.15"/>
      </geometry>
    </collision>

  </link>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CAMERA LINK  (forward ISR camera, 15° downward tilt)
  ═══════════════════════════════════════════════════════════════════════════ -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.10 0.0 -0.02" rpy="0 0.2618 0"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="0.025"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
      <material name="camera_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════════════
       IMU LINK  (co-located with base_link)
  ═══════════════════════════════════════════════════════════════════════════ -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GPS LINK
  ═══════════════════════════════════════════════════════════════════════════ -->
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <link name="gps_link">
    <inertial>
      <mass value="0.010"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="0.008"/>
      </geometry>
      <material name="gps_white">
        <color rgba="0.95 0.95 0.95 1.0"/>
      </material>
    </visual>
  </link>

</robot>
