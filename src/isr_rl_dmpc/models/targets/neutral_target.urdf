<?xml version="1.0"?>
<!--
  neutral_target.urdf — PyBullet URDF for neutral / civilian targets.

  Mesh source: CesiumGS CesiumMilkTruck.glb converted to OBJ (Apache 2.0)
  https://github.com/CesiumGS/cesium

  The Cesium Milk Truck is a ground-vehicle silhouette appropriate for
  neutral / civilian entities in the ISR simulation.

  Raw mesh extent ≈ 2.8 × 2.6 × 4.9 m.  Scaled to ≈ 3.9 m length.
-->
<robot name="neutral_target">

  <link name="base_link">

    <inertial>
      <mass value="0.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Scale raw ~4.9 m length to ~3.9 m (factor 0.8) -->
        <mesh filename="../meshes/cesium_milk_truck.obj" scale="0.8 0.8 0.8"/>
      </geometry>
      <material name="neutral_yellow">
        <color rgba="1.0 0.85 0.0 0.85"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.5 2.0 4.0"/>
      </geometry>
    </collision>

  </link>

</robot>
