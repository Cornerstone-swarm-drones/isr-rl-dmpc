<?xml version="1.0"?>
<!--
  friendly_target.urdf — PyBullet URDF for friendly targets.

  Mesh source: CesiumGS Box.glb converted to OBJ (Apache 2.0)
  https://github.com/CesiumGS/cesium

  A simple cube used as a friendly marker, coloured green.
  Raw mesh extent = 1 × 1 × 1 m.  Scaled to 2.0 m.
-->
<robot name="friendly_target">

  <link name="base_link">

    <inertial>
      <mass value="0.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>

    <visual>
      <!-- Z-offset = half of mesh height so the model sits on the ground plane -->
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/box.obj" scale="2.0 2.0 2.0"/>
      </geometry>
      <material name="friendly_green">
        <color rgba="0.1 0.9 0.2 0.85"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 1.0" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 2.0 2.0"/>
      </geometry>
    </collision>

  </link>

</robot>
